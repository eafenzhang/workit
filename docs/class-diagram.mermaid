classDiagram
    class ModelItem {
        +number id
        +string name
        +string provider
        +string baseUrl
        +string apiKey
        +boolean hasApiKey
        +string modelId
        +boolean enabled
        +boolean isDefault
        +string createdAt
    }

    class ProviderConfig {
        +string id
        +string name
        +string baseUrl
        +string endpoint
        +ModelOption[] models
        +string authType
    }

    class ModelOption {
        +string id
        +string name
    }

    class TokenStats {
        +getStats() Record~string, number~
        +getTotal() number
    }

    class ConfigFormData {
        +string apiKey
        +string modelId
        +string provider
        +string customName
        +string customBaseUrl
    }

    class ProviderLogoProps {
        +string providerId
        +number size
    }

    class StatsBarProps {
        +ModelItem[] models
        +TokenStats tokenStats
    }

    class ProviderCardProps {
        +ProviderConfig provider
        +ModelItem savedConfig
        +function onClick
    }

    class ApiKeyInputProps {
        +string value
        +function onChange
    }

    class ModelSelectorProps {
        +ProviderConfig provider
        +string value
        +function onChange
        +boolean isCustom
    }

    class ProviderSelectorProps {
        +ProviderConfig[] providers
        +string selectedId
        +function onSelect
    }

    class CustomProviderFieldsProps {
        +string name
        +string baseUrl
        +function onNameChange
        +function onBaseUrlChange
    }

    class ConfigModalProps {
        +boolean open
        +ModelItem editingModel
        +function onClose
        +function onSaved
        +ProviderConfig[] providers
    }

    ProviderConfig "1" *-- "1..*" ModelOption : models
    ModelItem ..> ProviderConfig : provider字段匹配
    ConfigFormData ..> ProviderConfig : provider字段匹配
    ConfigModalProps --> ModelItem : editingModel
    ConfigModalProps --> ProviderConfig : providers
    ProviderCardProps --> ProviderConfig : provider
    ProviderCardProps --> ModelItem : savedConfig
    ModelSelectorProps --> ProviderConfig : provider
    ProviderSelectorProps --> ProviderConfig : providers
