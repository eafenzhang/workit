{
  "name": "workit",
  "productName": "Workit",
  "version": "1.0.3",
  "description": "Workit 需求管理应用",
  "author": "Eafenzhang",
  "private": true,
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win --dir",
    "electron:dist": "vite build && electron-builder --win",
    "lint": "eslint ."
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.6",
