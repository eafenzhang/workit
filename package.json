{
  "name": "workit",
  "productName": "Workit",
  "version": "1.0.8",
  "description": "Workit 需求管理应用",
  "author": "Eafenzhang",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/kill-port.cjs && vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "download:aioncore": "node scripts/download-aioncore.cjs",
    "electron:dev": "vite build && electron .",
    "electron:build": "npm run download:aioncore && vite build && electron-builder --win --dir",
    "electron:dist": "npm run download:aioncore && vite build && electron-builder --win",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tiptap/extension-image": "^3.23.5",
    "@tiptap/extension-placeholder": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.6",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.555.0",
    "mammoth": "^1.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.0",
    "recharts": "^2.15.4",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.1.17",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^7.2.4",
    "vite-plugin-checker": "^0.12.0"
  },
  "build": {
    "appId": "ai.workit.app",
    "productName": "Workit",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "electron/preload.cjs",
      "electron/main.cjs",
      "electron/aioncore-manager.cjs",
      "electron/window.cjs",
      "electron/updater.cjs"
    ],
    "extraResources": [
      {
        "from": "electron/aioncore",
        "to": "aioncore",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/@modelcontextprotocol/**/*",
      "build/icon.png",
      "build/icon.ico",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "eafenzhang",
      "repo": "workit",
      "releaseType": "release"
    }
  }
}
